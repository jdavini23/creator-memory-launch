# Convex (generated by `npx convex init`)
VITE_CONVEX_URL=http://127.0.0.1:3210

# Clerk Authentication
# Get these from https://dashboard.clerk.com/
# 1. Create a new Clerk application
# 2. Go to API Keys → Copy "Publishable Key"
# 3. Go to API Keys → Copy "Secret Key" (for backend/webhooks)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# Clerk Webhook Secret (for user sync)
# 1. In Clerk Dashboard → Webhooks → Add Endpoint
# 2. URL: https://your-domain.com/api/clerk-webhook (or ngrok for local)
# 3. Events: user.created, user.updated, user.deleted
# 4. Copy "Signing Secret" → CLERK_WEBHOOK_SECRET
CLERK_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Convex Production (after `npx convex deploy`)
# CONVEX_DEPLOYMENT=prod:xxx
# VITE_CONVEX_URL=https://xxx.convex.cloud

# Notion OAuth (for source connections)
# 1. Create Notion Internal Integration at https://www.notion.so/my-integrations
# 2. Get "Internal Integration Secret" → NOTION_CLIENT_SECRET
# 3. Set Redirect URI: https://your-domain.com/api/auth/callback/notion
NOTION_CLIENT_ID=your_notion_client_id
NOTION_CLIENT_SECRET=your_notion_client_secret

# GitHub OAuth
# 1. Create OAuth App at https://github.com/settings/developers
# 2. Callback URL: https://your-domain.com/api/auth/callback/github
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# OpenAI (for embeddings & generation)
OPENAI_API_KEY=sk-your_openai_key_here

# Anthropic (for generation)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# Stripe (for billing)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable

# App URL (for OAuth callbacks)
VITE_APP_URL=http://localhost:3000